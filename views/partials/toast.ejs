<%
  // Decode URL-encoded messages
  const toastError = locals.flashError ? decodeURIComponent(locals.flashError) : null;
  const toastSuccess = locals.flashSuccess ? decodeURIComponent(locals.flashSuccess) : null;
  const hasToast = toastError || toastSuccess;
%>

<% if (hasToast) { %>
<style>
  .toast-wrapper {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 99999;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }
  .toast-pill {
    display: flex;
    align-items: center;
    gap: .65rem;
    padding: .75rem 1.1rem;
    border-radius: 10px;
    font-size: .875rem;
    font-weight: 500;
    color: #fff;
    min-width: 260px;
    max-width: 380px;
    box-shadow: 0 8px 24px rgba(0,0,0,.18);
    animation: toastIn .3s ease forwards;
    cursor: pointer;
  }
  .toast-pill.toast-error  { background: #e74c3c; }
  .toast-pill.toast-success { background: #27ae60; }
  .toast-pill .toast-icon { font-size: 1.1rem; flex-shrink: 0; }
  .toast-pill .toast-close {
    margin-left: auto;
    opacity: .75;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .toast-pill .toast-close:hover { opacity: 1; }
  @keyframes toastIn {
    from { opacity: 0; transform: translateX(60px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes toastOut {
    from { opacity: 1; transform: translateX(0); }
    to   { opacity: 0; transform: translateX(60px); }
  }
  .toast-pill.hiding {
    animation: toastOut .3s ease forwards;
  }
</style>

<div class="toast-wrapper" id="toastWrapper">
  <% if (toastError) { %>
  <div class="toast-pill toast-error" id="toastError">
    <span class="toast-icon">✕</span>
    <span><%= toastError %></span>
    <span class="toast-close" onclick="dismissToast('toastError')">✕</span>
  </div>
  <% } %>
  <% if (toastSuccess) { %>
  <div class="toast-pill toast-success" id="toastSuccess">
    <span class="toast-icon">✓</span>
    <span><%= toastSuccess %></span>
    <span class="toast-close" onclick="dismissToast('toastSuccess')">✕</span>
  </div>
  <% } %>
</div>

<script>
  function dismissToast(id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.add('hiding');
    setTimeout(function() { el.remove(); }, 300);
  }

  // Auto-dismiss after 4 seconds
  setTimeout(function() { dismissToast('toastError'); }, 4000);
  setTimeout(function() { dismissToast('toastSuccess'); }, 4500);
</script>
<% } %>
